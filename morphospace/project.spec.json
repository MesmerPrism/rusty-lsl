      "finite-sample-recovery",
      "fixed-width-numeric-sample",
      "integrated-clock-correction",
      "short-info-discovery-responder",
      "string-sample",
      "stream-handshake",
      "timestamped-float32-sample",
      "udp-discovery"
    ],
    "denied_modules": [],
    "allowed_permissions": [
      "clock read",
      "network access"
    ],
    "denied_permissions": [
      "device access",
      "native library loading",
      "process spawning"
    ],
    "data_classes": [
      "public source",
      "sanitized compatibility observations",
      "synthetic fixtures"
    ]
  },
