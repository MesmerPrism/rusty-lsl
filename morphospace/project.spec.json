  "non_scope": [
    "LSL runtime beyond the explicitly bounded caller-configured UDP discovery, TCP connection-setup, one-record timestamped float32, integrated clock-correction, bounded sample-queue, and finite caller-invoked recovery calls, including multicast membership, endpoint selection, other sample shapes/formats, periodic clocks, automatic reconnection, and FFI.",
    "Manifold stream admission, registry, subscriptions, routes, leases, revisions, authorization, or audit.",
    "Morphospace-native sample transport, platform lifecycle, Quest or Hostess adapters, and commands derived from inbound samples.",
    "Private evidence, local machine paths, device identities, credentials, raw captures, and copied or translated liblsl or rLSL source."
  ],
  "validation_profiles": [
    {
      "profile_id": "runtime-loopback",
      "commands": [
        "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/check_lslc_003b.ps1"
      ]
    },
    {
      "profile_id": "source-owner",
      "commands": [
        "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/check_all.ps1"
      ]
    },
    {
      "profile_id": "source-only",
      "commands": [
        "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/check_all.ps1"
      ]
    },
    {
      "profile_id": "workflow",
      "commands": [
        "powershell -NoProfile -ExecutionPolicy Bypass -File <work-environment-root>/scripts/Test-WorkflowContracts.ps1 -WorkspaceRoot <project-root>/morphospace"
      ]
    },
    {
      "profile_id": "device",
      "commands": [
        "Run the private serial-scoped Quest capsule declared by the current required-device unit and publish only its sanitized receipt."
      ]
    }
  ],
  "acceptance_profiles": [
    {
      "profile_id": "inert-default",
      "commands": [
        "Verify default activation remains disabled and the selected UDP discovery effect still requires its explicit runtime input."
      ]
    },
    {
      "profile_id": "rollback",
      "commands": [
        "Revert the current work-unit commit and rerun the source-only and workflow profiles."
      ]
    }
  ],
  "release_policy": {
    "versioning": "semver",
    "commit_policy": "Commit coherent validated source-only slices locally before integration.",
    "push_checkpoint": "integration-batch",
    "source_first": true,
    "planning_last": true,
    "force_push_allowed": false
  },
  "public_boundary": {
    "mode": "public",
    "private_overlay": "local/",
    "prohibited_evidence": [
      "credentials and signing material",
      "device identities",
      "local machine paths",
      "private planning history",
      "raw logs and captures"
    ]
  }
}
