        "THIRD_PARTY_NOTICES.md",
        "crates/",
        "docs/",
        "fixtures/",
        "morphospace/",
        "tools/"
      ]
    },
    {
      "repo_id": "rusty-quest",
      "role": "platform-test-harness",
      "path": "../rusty-quest",
      "allowed_paths": [
        "apps/lsl-multicast-conformance-android/",
        "tools/Build-LslMulticastConformanceAndroid.ps1",
        "tools/Test-LslMulticastConformanceAndroid.ps1"
      ]
    }
  ],
