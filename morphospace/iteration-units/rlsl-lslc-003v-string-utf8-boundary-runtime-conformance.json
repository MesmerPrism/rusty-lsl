      "acceptance_id": "observed-string-boundary-runtime-conformance",
      "command": "cargo test --workspace --all-targets --offline --locked lslc_003v",
      "proof": "The unchanged capability-gated runtime preserves both LSLC-003U value classes and exact timestamps through finite loopback with cleanup."
