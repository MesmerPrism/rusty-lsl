    {
      "acceptance_id": "no-production-or-authority-drift",
      "command": "python ./tools/check_lslc_003v.py",
      "proof": "Only test code and evidence/routes change; production framing, APIs, activation, dependencies, and authority remain unchanged."
    },
    {
      "acceptance_id": "project-policy-workflow",
      "command": "python ./tools/dispatch_validation.py --profile standard",
      "proof": "Standard policy, public boundary, instructions, documentation, and workflow contracts pass."
    }
